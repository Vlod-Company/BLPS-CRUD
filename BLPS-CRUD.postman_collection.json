{
  "info": {
    "_postman_id": "f1a4fbb8-5f75-4f7d-9e9d-df48b35832b8",
    "name": "BLPS-CRUD Public API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Flight - Search",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/flights?from={{fromAirport}}&to={{toAirport}}&date={{flightDate}}&passengers={{passengers}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "flights"
          ],
          "query": [
            {
              "key": "from",
              "value": "{{fromAirport}}"
            },
            {
              "key": "to",
              "value": "{{toAirport}}"
            },
            {
              "key": "date",
              "value": "{{flightDate}}"
            },
            {
              "key": "passengers",
              "value": "{{passengers}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (Array.isArray(data) && data.length > 0 && data[0].id) {",
              "  pm.collectionVariables.set('flightId', String(data[0].id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Flight - Get By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/flights/{{flightId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "flights",
            "{{flightId}}"
          ]
        }
      }
    },
    {
      "name": "Order - Create (Internal)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{userId}},\n  \"flightId\": {{flightId}},\n  \"currency\": \"RUB\",\n  \"seatNumber\": \"12A\",\n  \"seatClass\": \"ECONOMY\",\n  \"hasBaggage\": true,\n  \"passengerName\": \"Ivan Ivanov\",\n  \"passengerPassport\": \"1234 567890\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data && data.id) {",
              "  pm.collectionVariables.set('orderId', String(data.id));",
              "}"
            ]
          }
        }
      ]
    },
