    {
      "name": "Flight - Search",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (Array.isArray(data) && data.length > 0 && data[0].id) {",
              "  pm.collectionVariables.set('flightId', String(data[0].id));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/flights?from={{fromAirport}}&to={{toAirport}}&date={{flightDate}}&passengers={{passengers}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "flights"
          ],
          "query": [
            {
              "key": "from",
              "value": "{{fromAirport}}"
            },
            {
              "key": "to",
              "value": "{{toAirport}}"
            },
            {
              "key": "date",
              "value": "{{flightDate}}"
            },
            {
              "key": "passengers",
              "value": "{{passengers}}"
            }
          ]
        }
      },
      "response": []
    },
