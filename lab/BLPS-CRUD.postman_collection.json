{
  "info": {
    "_postman_id": "9729dd76-8759-4224-b3b9-6f6a70d9bf5b",
    "name": "BLPS-CRUD Camunda 7 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Camunda 7 happy-path checks for Process_Main and payment callback correlation."
  },
  "item": [
    {
      "name": "Camunda 7 Process",
      "description": "Run requests from top to bottom. The search task completion intentionally sends no from/to/date variables: the process has already received flightId on start, so showFlightsDelegate uses that selected flight.",
      "item": [
        {
          "name": "1. Start Purchase Process",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('process started', function () { pm.expect(data.processInstanceId).to.be.a('string'); });",
                  "pm.collectionVariables.set('camundaProcessInstanceId', data.processInstanceId);",
                  "pm.collectionVariables.set('camundaProcessDefinitionId', data.processDefinitionId);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userLogin}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flightId\": {{flightId}},\n  \"currency\": \"RUB\",\n  \"seatNumber\": \"12A\",\n  \"seatClass\": \"ECONOMY\",\n  \"hasBaggage\": true,\n  \"passengerName\": \"Ivan Ivanov\",\n  \"passengerPassport\": \"1234 567890\",\n  \"provider\": \"internal-bank\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/process/purchase/start",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "process",
                "purchase",
                "start"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2. List Active User Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const tasks = pm.response.json();",
                  "const processInstanceId = pm.collectionVariables.get('camundaProcessInstanceId');",
                  "const task = tasks.find(t => t.processInstanceId === processInstanceId) || tasks[0];",
                  "pm.test('task found', function () { pm.expect(task).to.exist; });",
                  "pm.collectionVariables.set('camundaTaskId', task.id);",
                  "pm.collectionVariables.set('camundaTaskDefinitionKey', task.taskDefinitionKey);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userLogin}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/process/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "process",
                "tasks"
              ]
            }
          },
          "response": []
        },
        {
          "name": "3. Complete Search Task",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userLogin}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/process/tasks/{{camundaTaskId}}/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "process",
                "tasks",
                "{{camundaTaskId}}",
                "complete"
              ]
            }
          },
          "response": []
        },
        {
          "name": "4. Refresh Select Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const tasks = pm.response.json();",
                  "const processInstanceId = pm.collectionVariables.get('camundaProcessInstanceId');",
                  "const task = tasks.find(t => t.processInstanceId === processInstanceId && t.taskDefinitionKey === 'Task_User_Select') || tasks.find(t => t.processInstanceId === processInstanceId);",
                  "pm.test('select task found', function () { pm.expect(task).to.exist; pm.expect(task.taskDefinitionKey).to.eql('Task_User_Select'); });",
                  "pm.collectionVariables.set('camundaTaskId', task.id);",
                  "pm.collectionVariables.set('camundaTaskDefinitionKey', task.taskDefinitionKey);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userLogin}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/process/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "process",
                "tasks"
              ]
            }
          },
          "response": []
        },
        {
          "name": "5. Complete Select Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('order created', function () { pm.expect(data.variables.orderId).to.exist; });",
                  "pm.collectionVariables.set('orderId', String(data.variables.orderId));",
                  "if (data.variables.paymentSessionId) { pm.collectionVariables.set('paymentSessionId', String(data.variables.paymentSessionId)); }",
                  "if (data.variables.redirectUrl) { pm.collectionVariables.set('paymentRedirectUrl', String(data.variables.redirectUrl)); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userLogin}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variables\": {\n    \"method\": \"internal\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/process/tasks/{{camundaTaskId}}/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "process",
                "tasks",
                "{{camundaTaskId}}",
                "complete"
              ]
            }
          },
          "response": []
        },
        {
          "name": "6. Payment Callback",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{adminLogin}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": {{orderId}},\n  \"success\": true,\n  \"externalPaymentId\": \"{{paymentId}}\",\n  \"failureReason\": null,\n  \"paidAmount\": {{paidAmount}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/internal-purchases/callback",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "internal-purchases",
                "callback"
              ]
            }
          },
          "response": []
        },
        {
          "name": "7. Check Tasks After Callback",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userLogin}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/process/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "process",
                "tasks"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
